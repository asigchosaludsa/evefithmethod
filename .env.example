# ----------------------------------------------------------------------------
# EveFit Method — environment variables
# Copy to .env.local for local development. NEVER commit real secrets.
# ----------------------------------------------------------------------------

# Public URLs (safe to expose)
NEXT_PUBLIC_SITE_URL=https://app.evefitmethod.com
NEXT_PUBLIC_MARKETING_URL=https://evefitmethod.com

# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=
# New-style publishable key (preferred). Legacy projects can use the anon key instead
# via NEXT_PUBLIC_SUPABASE_ANON_KEY (the app accepts either).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only — NEVER expose to the client)
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# Optional / future (not implemented yet — leave blank)
# ----------------------------------------------------------------------------
# RESEND_API_KEY=
# POSTMARK_API_KEY=
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
